{
  "name": "licensing-server",
  "version": "1.0.0",
  "description": "SMM Panel Licensing Server - NestJS (Compiled Binary)",
  "main": "dist/main.js",
  "bin": "dist/main.js",
  "scripts": {
    "build": "nest build",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main.js",
    "compile": "pkg . --targets node18-win-x64 --output licensing-server.exe"
  },
  "pkg": {
    "assets": [
      "dist/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "outputPath": "releases"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "class-validator": "^0.14.0",
    "class-transformer": "^0.5.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@types/express": "^4.17.17",
    "@types/node": "^20.3.1",
    "typescript": "^5.1.3",
    "pkg": "^5.8.1"
  }
}
